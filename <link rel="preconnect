<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#0a0a0a;--surface:rgba(255,255,255,0.03);--surface-hover:rgba(255,255,255,0.06);
  --border:rgba(255,255,255,0.06);--border-hover:rgba(255,255,255,0.12);
  --text:#fafafa;--text-s:rgba(255,255,255,0.5);--text-t:rgba(255,255,255,0.3);
  --accent:#e8e8e8;--green:#34d399;--radius:12px;
}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:'Inter',-apple-system,sans-serif;line-height:1.6;overflow-x:hidden;-webkit-font-smoothing:antialiased}
body::before{content:'';position:fixed;inset:0;z-index:0;opacity:.02;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");pointer-events:none}

/* Ambient */
.ambient{position:fixed;inset:0;z-index:0;overflow:hidden;pointer-events:none}
.ambient-orb{position:absolute;border-radius:50%;filter:blur(120px);opacity:.06}
.ambient-orb:nth-child(1){width:600px;height:600px;background:#6366f1;top:-200px;right:-100px;animation:afloat 20s ease-in-out infinite}
.ambient-orb:nth-child(2){width:500px;height:500px;background:#a855f7;bottom:-150px;left:-100px;animation:afloat 25s ease-in-out infinite reverse}
@keyframes afloat{0%,100%{transform:translate(0,0)}33%{transform:translate(30px,-30px)}66%{transform:translate(-20px,20px)}}

/* Scrollbar */
::-webkit-scrollbar{width:6px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:rgba(255,255,255,.08);border-radius:3px}

/* NAV */
.nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:0 5%;height:64px;display:flex;align-items:center;justify-content:space-between;background:rgba(10,10,10,.8);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);transition:transform .4s ease}
.nav.hidden-nav{transform:translateY(-100%)}
.nav-logo{display:flex;align-items:center;gap:8px;font-weight:600;font-size:18px;color:var(--text);text-decoration:none}
.nav-logo img{height:36px;width:auto;object-fit:contain}
.nav-right{display:flex;align-items:center;gap:12px}
.nav-links{display:flex;gap:28px;margin-right:32px}
.nav-links a{color:var(--text-t);font-size:13px;font-weight:500;text-decoration:none;letter-spacing:.02em;transition:color .3s;position:relative}
.nav-links a::after{content:'';position:absolute;bottom:-4px;left:0;width:0;height:1px;background:var(--text);transition:width .3s}
.nav-links a:hover{color:var(--text)}
.nav-links a:hover::after{width:100%}

/* Hamburger */
.hamburger{display:none;flex-direction:column;justify-content:space-around;width:28px;height:20px;cursor:pointer;z-index:1000}
.hamburger span{width:100%;height:2px;background:var(--text);border-radius:2px;transition:all .3s ease}
.hamburger.active span:nth-child(1){transform:rotate(45deg) translate(6px,6px)}
.hamburger.active span:nth-child(2){opacity:0}
.hamburger.active span:nth-child(3){transform:rotate(-45deg) translate(6px,-6px)}

/* Mobile menu */
.mobile-menu{position:fixed;top:0;right:-100%;height:100vh;width:280px;background:rgba(10,10,10,.95);backdrop-filter:blur(24px);border-left:1px solid var(--border);display:flex;flex-direction:column;padding:80px 32px 32px;z-index:999;transition:right .4s cubic-bezier(.4,0,.2,1)}
.mobile-menu.active{right:0}
.mobile-menu a{color:var(--text-s);font-size:16px;font-weight:500;text-decoration:none;padding:14px 0;border-bottom:1px solid var(--border);transition:color .3s,padding-left .3s}
.mobile-menu a:hover{color:var(--text);padding-left:8px}

/* Auth buttons in nav */
.btn-nav{padding:8px 20px;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;border:none;transition:all .3s;font-family:inherit}
.btn-nav-primary{background:var(--text);color:var(--bg)}
.btn-nav-primary:hover{opacity:.85}
.btn-nav-outline{background:transparent;border:1px solid var(--border);color:var(--text-s)}
.btn-nav-outline:hover{border-color:var(--border-hover);color:var(--text)}
.btn-nav-danger{background:transparent;border:1px solid rgba(239,68,68,.3);color:#ef4444}
.btn-nav-danger:hover{background:rgba(239,68,68,.1)}
#user-profile img{width:34px;height:34px;border-radius:50%;border:2px solid var(--border);object-fit:cover}

/* HERO */
.hero{min-height:100vh;display:flex;align-items:center;justify-content:center;text-align:center;position:relative;padding:120px 24px 80px}
.hero-inner{max-width:800px;position:relative;z-index:2}
.hero h1{font-family:'Playfair Display',serif;font-size:clamp(2.5rem,7vw,5rem);font-weight:400;line-height:1.05;letter-spacing:-.03em;margin-bottom:24px}
.hero h1 .highlight{color:var(--text-s);font-style:italic}
.hero-typing{font-size:clamp(1rem,2.5vw,1.25rem);color:var(--text-t);font-weight:300;margin-bottom:36px;min-height:36px}
.hero-typing::after{content:'|';animation:blink .8s infinite;margin-left:2px}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0}}
.hero-btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-bottom:40px}
.btn-hero{padding:14px 32px;border-radius:var(--radius);font-size:14px;font-weight:600;text-decoration:none;transition:all .3s cubic-bezier(.4,0,.2,1);font-family:inherit;cursor:pointer;display:inline-flex;align-items:center;gap:8px}
.btn-hero-primary{background:var(--text);color:var(--bg);border:none}
.btn-hero-primary:hover{opacity:.85;transform:translateY(-2px);box-shadow:0 12px 40px rgba(255,255,255,.1)}
.btn-hero-outline{background:transparent;color:var(--text-s);border:1px solid var(--border)}
.btn-hero-outline:hover{border-color:var(--border-hover);color:var(--text)}
.social-links{display:flex;gap:20px;justify-content:center}
.social-links a{color:var(--text-t);font-size:20px;transition:color .3s,transform .3s;text-decoration:none}
.social-links a:hover{color:var(--text);transform:translateY(-2px)}

/* SECTIONS */
section{padding:120px 24px;position:relative;z-index:1}
.section-inner{max-width:1100px;margin:0 auto}
.section-label{font-size:11px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--text-t);margin-bottom:12px}
.section-title{font-family:'Playfair Display',serif;font-size:clamp(2rem,4vw,3rem);font-weight:400;letter-spacing:-.02em;margin-bottom:48px;color:var(--text)}

/* ABOUT */
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center}
.about-img{border-radius:16px;overflow:hidden;border:1px solid var(--border)}
.about-img img{width:100%;height:auto;display:block;transition:transform .6s ease}
.about-img:hover img{transform:scale(1.03)}
.about-text p{color:var(--text-s);font-size:15px;line-height:1.8;margin-bottom:20px;font-weight:300}
.about-text strong{color:var(--text);font-weight:500}
.about-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:24px;margin-top:24px}
.about-card h3{font-size:16px;font-weight:600;margin-bottom:8px;display:flex;align-items:center;gap:10px}
.about-card p{color:var(--text-t);font-size:14px;line-height:1.7;margin:0}

/* PROJECTS */
.project-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:24px}
.project-card{background:var(--surface);border:1px solid var(--border);border-radius:16px;overflow:hidden;transition:all .4s cubic-bezier(.4,0,.2,1)}
.project-card:hover{border-color:var(--border-hover);transform:translateY(-4px);box-shadow:0 20px 60px rgba(0,0,0,.3)}
.project-card img{width:100%;height:200px;object-fit:cover;transition:transform .5s}
.project-card:hover img{transform:scale(1.05)}
.project-info{padding:24px}
.project-info h3{font-size:18px;font-weight:600;margin-bottom:8px}
.project-info p{font-size:13px;color:var(--text-t);margin-bottom:16px;line-height:1.6}
.tags{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:20px}
.tag{background:rgba(255,255,255,.04);border:1px solid var(--border);padding:4px 12px;border-radius:100px;font-size:11px;color:var(--text-t);font-weight:500}
.btn-card{display:inline-flex;align-items:center;gap:6px;padding:10px 20px;background:var(--surface-hover);border:1px solid var(--border);border-radius:8px;color:var(--text-s);font-size:13px;font-weight:500;text-decoration:none;transition:all .3s}
.btn-card:hover{background:rgba(255,255,255,.08);color:var(--text);border-color:var(--border-hover)}

/* SUPPORT */
.support-card{max-width:440px;margin:0 auto;background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:40px;text-align:center}
.support-card h3{font-size:20px;font-weight:600;margin-bottom:12px}
.support-card>p{font-size:14px;color:var(--text-s);margin-bottom:24px;line-height:1.7}
.support-card img{width:100%;max-width:240px;border-radius:12px;margin:0 auto 20px;display:block;border:1px solid var(--border)}
.support-card .btn-card{width:100%;justify-content:center;margin-top:8px}

/* CONTACT */
.contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;max-width:800px;margin:0 auto}
.contact-info{display:flex;flex-direction:column;gap:20px;justify-content:center}
.contact-item{display:flex;align-items:center;gap:14px;color:var(--text-s);font-size:14px}
.contact-item i{font-size:18px;color:var(--text-t);width:24px;text-align:center}
.contact-item a{color:var(--text-s);text-decoration:none;transition:color .3s}
.contact-item a:hover{color:var(--text)}
.contact-form{display:flex;flex-direction:column;gap:16px}
.contact-form label{font-size:12px;font-weight:500;color:var(--text-t);text-transform:uppercase;letter-spacing:.04em;margin-bottom:-8px}
.contact-form input,.contact-form textarea{width:100%;padding:14px 16px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);color:var(--text);font-family:inherit;font-size:14px;outline:none;transition:all .25s;resize:vertical}
.contact-form input:focus,.contact-form textarea:focus{border-color:rgba(255,255,255,.2);background:var(--surface-hover);box-shadow:0 0 0 3px rgba(255,255,255,.04)}
.contact-form input::placeholder,.contact-form textarea::placeholder{color:var(--text-t)}
.btn-submit{width:100%;padding:14px;background:var(--text);color:var(--bg);border:none;border-radius:var(--radius);font-size:14px;font-weight:600;cursor:pointer;transition:all .3s;font-family:inherit}
.btn-submit:hover{opacity:.85;transform:translateY(-1px)}

/* FOOTER */
.site-footer{border-top:1px solid var(--border);padding:64px 24px;position:relative;z-index:1}
.footer-grid{display:grid;grid-template-columns:2fr 1fr 1fr 2fr;gap:40px;max-width:1100px;margin:0 auto}
.footer-brand p{font-size:13px;color:var(--text-t);margin-top:8px;line-height:1.7}
.footer-col h4{font-size:13px;font-weight:600;color:var(--text-s);margin-bottom:16px;letter-spacing:.04em;text-transform:uppercase}
.footer-col a,.footer-col li{color:var(--text-t);font-size:13px;text-decoration:none;transition:color .3s;display:block;padding:4px 0;list-style:none}
.footer-col a:hover,.footer-col li:hover{color:var(--text)}
.footer-partners li{display:flex;align-items:center;gap:8px;padding:4px 0}
.footer-partners li a{display:inline-flex;padding:0}

/* TOAST */
#toast{position:fixed;top:24px;right:24px;z-index:9999;min-width:320px;background:rgba(15,15,15,.95);backdrop-filter:blur(16px);border:1px solid var(--border);border-radius:var(--radius);padding:16px 20px;transform:translateX(140%);transition:transform .5s cubic-bezier(.34,1.56,.64,1)}
#toast.show{transform:translateX(0)}
.toast-success{border-left:3px solid var(--green)}
.toast-error{border-left:3px solid #ef4444}
.toast-inner{display:flex;align-items:start;gap:12px}
#toast-title{font-weight:600;font-size:14px}
#toast-msg{font-size:13px;color:var(--text-s)}

/* Auth Modal */
.auth-overlay{position:fixed;inset:0;z-index:200;background:rgba(0,0,0,.7);backdrop-filter:blur(20px);display:none;align-items:center;justify-content:center}
.auth-overlay.show{display:flex}
.auth-modal{background:#111;border:1px solid var(--border-hover);border-radius:16px;width:90%;max-width:380px;padding:32px;animation:modalSlide .4s cubic-bezier(.16,1,.3,1)}
@keyframes modalSlide{from{transform:scale(.96) translateY(12px);opacity:0}to{transform:scale(1) translateY(0);opacity:1}}
.auth-modal h5{font-family:'Playfair Display',serif;font-size:22px;font-weight:400;margin-bottom:24px}
.auth-modal .btn-close{position:absolute;top:16px;right:16px;background:none;border:none;color:var(--text-t);font-size:20px;cursor:pointer}
.auth-modal input{width:100%;padding:12px 16px;background:var(--surface);border:1px solid var(--border);border-radius:8px;color:var(--text);font-family:inherit;font-size:14px;outline:none;margin-bottom:12px;transition:border-color .25s}
.auth-modal input:focus{border-color:rgba(255,255,255,.2)}
.auth-modal .divider{display:flex;align-items:center;gap:12px;margin:20px 0;color:var(--text-t);font-size:12px}
.auth-modal .divider hr{flex:1;border:none;border-top:1px solid var(--border)}

/* Reveal animations */
.reveal{opacity:0;transform:translateY(30px);transition:all .8s cubic-bezier(.4,0,.2,1)}
.reveal.visible{opacity:1;transform:translateY(0)}

/* Responsive */
@media(max-width:992px){
  .nav-links{display:none}
  .hamburger{display:flex}
  .about-grid{grid-template-columns:1fr;gap:40px}
  .contact-grid{grid-template-columns:1fr}
  .footer-grid{grid-template-columns:1fr 1fr;gap:32px}
}
@media(max-width:600px){
  .project-grid{grid-template-columns:1fr}
  .footer-grid{grid-template-columns:1fr}
  section{padding:80px 20px}
}
.d-none{display:none!important}
</style>

